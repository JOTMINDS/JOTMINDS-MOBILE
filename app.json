{
  "expo": {
    "name": "JotMinds",
    "slug": "jotminds-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "jotminds",
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jotminds.mobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.jotminds.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/ionicons.ttf",
            "./assets/fonts/material-community.ttf"
          ]
        }
      ],
      "expo-asset",
      [
        "expo-splash-screen",
        {
          "image": "./assets/logo.png",
          "imageWidth": 240,
          "resizeMode": "contain",
          "backgroundColor": "#0F172B"
        }
      ],
      "@react-native-community/datetimepicker",
      "./plugins/withFmtCxx17Fix"
    ],
    "extra": {
      "eas": {
        "projectId": "1f01b3b9-21f2-44e9-b34d-22dcfe4c5790"
      }
    },
    "owner": "jotminds-mobile"
  }
}
